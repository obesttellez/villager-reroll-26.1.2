{
  "schemaVersion": 1,
  "id": "fabric-creative-tab-api-v1",
  "name": "Fabric Creative Tab API (v1)",
  "version": "${version}",
  "environment": "*",
  "license": "Apache-2.0",
  "icon": "assets/fabric-creative-tab-api-v1/icon.png",
  "contact": {
    "homepage": "https://fabricmc.net",
    "irc": "irc://irc.esper.net:6667/fabric",
    "issues": "https://github.com/FabricMC/fabric/issues",
    "sources": "https://github.com/FabricMC/fabric"
  },
  "authors": [
    "FabricMC"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api-base": "*",
    "fabric-resource-loader-v1": "*"
  },
  "description": "An API for adding custom item groups.",
  "mixins": [
    "fabric-creative-tab-api-v1.mixins.json",
    {
      "config": "fabric-creative-tab-api-v1.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "fabric-creative-tab-api-v1.classtweaker",
  "custom": {
    "fabric-api:module-lifecycle": "stable"
  }
}
