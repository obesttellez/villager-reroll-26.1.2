unpick v4

group int pufferfish_state
	net.minecraft.entity.passive.PufferfishEntity.NOT_PUFFED
	net.minecraft.entity.passive.PufferfishEntity.SEMI_PUFFED
	net.minecraft.entity.passive.PufferfishEntity.FULLY_PUFFED

target_method net.minecraft.entity.passive.PufferfishEntity setPuffState (I)V
	param 0 pufferfish_state
