	net.minecraft.block.enums.TrialSpawnerState$DisplayRotationSpeed.NONE
	net.minecraft.block.enums.TrialSpawnerState$DisplayRotationSpeed.SLOW
	net.minecraft.block.enums.TrialSpawnerState$DisplayRotationSpeed.FAST

