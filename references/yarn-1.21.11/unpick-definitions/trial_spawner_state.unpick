unpick v4

group int trial_spawner_luminance
	net.minecraft.block.enums.TrialSpawnerState$Luminance.NONE
	net.minecraft.block.enums.TrialSpawnerState$Luminance.LOW
	net.minecraft.block.enums.TrialSpawnerState$Luminance.HIGH

