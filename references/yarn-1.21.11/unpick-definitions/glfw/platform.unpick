unpick v4

group int glfw_platform_value
	org.lwjgl.glfw.GLFW.GLFW_ANY_PLATFORM
	org.lwjgl.glfw.GLFW.GLFW_PLATFORM_WIN32
	org.lwjgl.glfw.GLFW.GLFW_PLATFORM_COCOA
	org.lwjgl.glfw.GLFW.GLFW_PLATFORM_WAYLAND
	org.lwjgl.glfw.GLFW.GLFW_PLATFORM_X11
	org.lwjgl.glfw.GLFW.GLFW_PLATFORM_NULL

target_method org.lwjgl.glfw.GLFW glfwGetPlatform ()I
	return glfw_platform_value
