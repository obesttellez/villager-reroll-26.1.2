unpick v4

group int mod
	@flags
	@format hex
	net.minecraft.client.util.InputUtil.GLFW_MOD_SHIFT
	net.minecraft.client.util.InputUtil.GLFW_MOD_CONTROL
	net.minecraft.client.util.InputUtil.GLFW_MOD_ALT
	net.minecraft.client.util.InputUtil.GLFW_MOD_SUPER
	net.minecraft.client.util.InputUtil.GLFW_MOD_CAPS_LOCK
	net.minecraft.client.util.InputUtil.GLFW_MOD_NUM_LOCK