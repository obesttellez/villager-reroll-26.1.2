unpick v4

group int set_block_state_flags
	@flags
	net.minecraft.block.Block.NOTIFY_ALL
	net.minecraft.block.Block.NOTIFY_NEIGHBORS
	net.minecraft.block.Block.NOTIFY_LISTENERS
	net.minecraft.block.Block.NO_REDRAW
	net.minecraft.block.Block.REDRAW_ON_MAIN_THREAD
	net.minecraft.block.Block.FORCE_STATE
	net.minecraft.block.Block.SKIP_DROPS
	net.minecraft.block.Block.MOVED
	net.minecraft.block.Block.SKIP_LIGHTING_UPDATES

target_method net.minecraft.world.ModifiableWorld setBlockState (Lnet/minecraft/util/math/BlockPos;Lnet/minecraft/block/BlockState;I)Z
	param 2 set_block_state_flags
